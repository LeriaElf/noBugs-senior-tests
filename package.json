    "axios": "^1.13.2",
    "chai": "^6.2.2",
    "chai-json-schema-ajv": "^5.2.4",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "randexp": "^0.5.3"
